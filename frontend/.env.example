# ─── TradVue Frontend — Environment Variables ────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it's in .gitignore.

# Backend API URL (local dev default shown)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Google Analytics 4 Measurement ID
# Get this from: Google Analytics → Admin → Data Streams → Web → Measurement ID
# Format: G-XXXXXXXXXX
# Leave blank to disable analytics (also disabled automatically in dev/non-production builds)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Legacy alias (still works, new key takes priority)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
