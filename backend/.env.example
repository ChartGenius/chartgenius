# ================================================================
# TradVue Backend — Environment Variables
# Copy to .env and fill in your values
#
# 🔴 RENDER DEPLOYMENT: The following are REQUIRED in Render dashboard:
#    DATABASE_URL  — Supabase connection string (Transaction mode, port 6543)
#    JWT_SECRET    — Random 256-bit string: openssl rand -hex 32
#    FINNHUB_API_KEY
#    NODE_ENV=production
#    PORT=10000    — Render's default port (app reads process.env.PORT)
#
# Service: tradvue-api on Render (Hobby plan, Starter instance, $7/mo)
# URL: https://tradvue-api.onrender.com
# Auto-deploys on push to master via GitHub integration.
#
# See DEPLOYMENT_CHECKLIST.md for full Render setup guide.
# ================================================================

# Server
NODE_ENV=production
PORT=10000     # Use 10000 on Render (Render's default), 3001 for local dev

# ────────────────────────────────────────────
# Database (PostgreSQL)
# ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tradvue
DB_USER=postgres
DB_PASSWORD=your_password_here
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/tradvue

# ────────────────────────────────────────────
# Cache (Redis)
# ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ────────────────────────────────────────────
# Auth
# ────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_change_in_production_use_256bit_random
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ────────────────────────────────────────────
# Market Data
# ────────────────────────────────────────────

# Finnhub (FREE tier: 60 req/min, WebSocket real-time)
# Register free: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key

# Alpha Vantage (FREE tier: 5 req/min, 500/day)
# Register free: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# ────────────────────────────────────────────
# News
# ────────────────────────────────────────────

# NewsAPI (FREE for development, paid for production deployment)
# Register: https://newsapi.org/register
# Note: RSS feeds work without any key — NewsAPI is an optional enhancement
NEWS_API_KEY=your_news_api_key

# ────────────────────────────────────────────
# Economic Data
# ────────────────────────────────────────────

# FRED (Federal Reserve Economic Data) — completely FREE, no rate limits
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# ────────────────────────────────────────────
# Crypto Data
# ────────────────────────────────────────────

# Etherscan (optional, for on-chain crypto data)
# Register: https://etherscan.io/register
ETHERSCAN_API_KEY=your_etherscan_api_key

# ────────────────────────────────────────────
# Currency / Forex
# ────────────────────────────────────────────

# ExchangeRatesAPI (optional, for currency conversion)
# Register: https://exchangeratesapi.io
EXCHANGE_RATES_API_KEY=your_exchange_rates_api_key

# ────────────────────────────────────────────
# Admin
# ────────────────────────────────────────────

# Admin endpoint authentication key (internal use only)
# Generate: openssl rand -hex 32
ADMIN_KEY=your_admin_key_here

# ────────────────────────────────────────────
# Rate Limiting
# ────────────────────────────────────────────
RATE_LIMIT_WINDOW=15         # minutes
RATE_LIMIT_FREE=100          # requests per window
RATE_LIMIT_PRO=1000
RATE_LIMIT_ENTERPRISE=5000
